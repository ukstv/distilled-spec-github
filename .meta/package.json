{
  "name": "github-spec",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch-specs": "bun run fetch-specs.ts",
    "tsc": "tsc --noEmit",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "check": "bun run tsc && bun run lint && bun run fmt:check"
  },
  "workspaces": {
    "catalog": {
      "@typescript/native-preview": "latest",
      "oxfmt": "0.21.0",
      "oxlint": "1.36.0"
    }
  },
  "dependencies": {
    "@typescript/native-preview": "catalog:",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:"
  }
}